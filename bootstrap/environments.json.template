{
  "description": "Environment registry — the single source of truth for this project's environments. Every environment name used by runtime stamps (env.environments), cloud stamps (environments), env-var stamps (environments), and the deploy pipeline must be a key under `environments` here. Read by .claude/skills/environment/environment.sh. See .claude/environment-rules.md.",
  "default": "local",
  "environments": {
    "local": {
      "description": "Local development on your own machine.",
      "env_file": ".env",
      "version_env": "local",
      "publish_to": null,
      "deploy_to": null,
      "requires_approval": false
    },
    "staging": {
      "description": "Shared pre-production environment.",
      "env_file": ".env.staging",
      "version_env": "staging",
      "publish_to": null,
      "deploy_to": null,
      "requires_approval": false
    },
    "prod": {
      "description": "Production.",
      "env_file": ".env.production",
      "version_env": "prod",
      "publish_to": null,
      "deploy_to": null,
      "requires_approval": true
    }
  }
}
