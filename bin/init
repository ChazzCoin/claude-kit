#!/usr/bin/env bash
#
# claude-kit init — bootstrap a project with the claude-kit foundation.
#
# Usage:
#   claude-kit/bin/init [target-dir]
#
# If [target-dir] is omitted, the current working directory is used.
#
# Behavior:
#   - kit/* files are copied into <target>/.claude/ (overwriting any
#     existing kit-managed files; project files are untouched).
#   - bootstrap/* files are copied with the .template extension stripped
#     ONLY if the target file doesn't already exist. Existing
#     CLAUDE.md / PHASES.md / ROADMAP.md / AUDIT.md are preserved.
#   - tasks/{backlog,active,done}/ and docs/{decisions,postmortems}/
#     are created with .gitkeep files if missing.
#   - .claude/foundation.json is stamped with this kit's HEAD commit SHA
#     so /sync knows what to compare against.
#
# This script is intentionally simple. It uses cp + mkdir, no curl, no
# network calls. The kit must already be on disk (clone it first).

set -euo pipefail

TARGET="${1:-$PWD}"
TARGET="$(cd "$TARGET" && pwd)"

KIT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
KIT_REPO_URL="https://github.com/ChazzCoin/claude-kit"

# Resolve the kit's commit SHA. If the kit isn't a git repo (e.g. user
# downloaded a tarball), fall back to "unpinned" — /sync will still
# work but will treat every file as potentially-drifted on first run.
if git -C "$KIT_DIR" rev-parse HEAD >/dev/null 2>&1; then
  KIT_SHA="$(git -C "$KIT_DIR" rev-parse HEAD)"
  KIT_BRANCH="$(git -C "$KIT_DIR" rev-parse --abbrev-ref HEAD)"
else
  KIT_SHA="unpinned"
  KIT_BRANCH="main"
fi

echo "claude-kit init"
echo "  source: $KIT_DIR (sha: ${KIT_SHA:0:12}, branch: $KIT_BRANCH)"
echo "  target: $TARGET"
echo

# --- 1. Sync kit/ files (overwrite policy) ----------------------------

echo "→ Installing kit files into $TARGET/.claude/"
mkdir -p "$TARGET/.claude"

# kit/skills/ → .claude/skills/  (mirror)
if [ -d "$KIT_DIR/kit/skills" ]; then
  mkdir -p "$TARGET/.claude/skills"
  # Copy each skill subdirectory. We don't `rm -rf` first — that would
  # delete project-only skills. We just overlay.
  for skill in "$KIT_DIR/kit/skills"/*/; do
    [ -d "$skill" ] || continue
    name="$(basename "$skill")"
    cp -R "$skill" "$TARGET/.claude/skills/$name"
    echo "    skill: $name"
  done
fi

# kit/*.md → .claude/<filename>
# Picks up task-rules.md, task-template.md, and every platform-prefix
# file (ios-task-rules.md, web-task-rules.md, ios-conventions.md, and
# any future <platform>-*.md the kit ships). Iterating means new kit
# files get installed without an init-script edit — the kind of drift
# fix that motivated this loop in the first place.
for f in "$KIT_DIR/kit"/*.md; do
  [ -f "$f" ] || continue
  name="$(basename "$f")"
  cp "$f" "$TARGET/.claude/$name"
  echo "    kit:   $name"
done

# kit/modes/*.md → .claude/modes/*.md
# Mode definitions (drive prose). Activated via /mode <name>; the
# skill copies the activation record to .claude/mode.md (project-owned,
# never synced). Each *.md here is one mode.
if [ -d "$KIT_DIR/kit/modes" ]; then
  mkdir -p "$TARGET/.claude/modes"
  for f in "$KIT_DIR/kit/modes"/*.md; do
    [ -f "$f" ] || continue
    name="$(basename "$f")"
    cp "$f" "$TARGET/.claude/modes/$name"
    echo "    mode:  $name"
  done
fi

# --- 2. Bootstrap files (skip if exists) ------------------------------

echo
echo "→ Installing bootstrap templates (preserving any existing files)"

bootstrap_copy() {
  local src="$1"
  local dst="$2"
  local label="$3"
  if [ -f "$dst" ]; then
    echo "    skip:    $label  (exists)"
    return
  fi
  mkdir -p "$(dirname "$dst")"
  cp "$src" "$dst"
  echo "    create:  $label"
}

bootstrap_copy "$KIT_DIR/bootstrap/CLAUDE.md.template"    "$TARGET/CLAUDE.md"            "CLAUDE.md"
bootstrap_copy "$KIT_DIR/bootstrap/PHASES.md.template"    "$TARGET/tasks/PHASES.md"      "tasks/PHASES.md"
bootstrap_copy "$KIT_DIR/bootstrap/ROADMAP.md.template"   "$TARGET/tasks/ROADMAP.md"     "tasks/ROADMAP.md"
bootstrap_copy "$KIT_DIR/bootstrap/AUDIT.md.template"     "$TARGET/tasks/AUDIT.md"       "tasks/AUDIT.md"

# Primitive layer (v0.5.0+) — small files that personalize the project's
# Claude experience. Each is skip-if-exists, so re-runs preserve user edits.
bootstrap_copy "$KIT_DIR/bootstrap/pact.md.template"      "$TARGET/.claude/pact.md"      ".claude/pact.md"
bootstrap_copy "$KIT_DIR/bootstrap/welcome.md.template"   "$TARGET/.claude/welcome.md"   ".claude/welcome.md"
bootstrap_copy "$KIT_DIR/bootstrap/wont-do.md.template"   "$TARGET/.claude/wont-do.md"   ".claude/wont-do.md"
bootstrap_copy "$KIT_DIR/bootstrap/playlists.md.template" "$TARGET/.claude/playlists.md" ".claude/playlists.md"
bootstrap_copy "$KIT_DIR/bootstrap/bookmarks.md.template" "$TARGET/.claude/bookmarks.md" ".claude/bookmarks.md"

# --- 3. foundation.json (stamped with current kit SHA) ----------------

FOUNDATION_FILE="$TARGET/.claude/foundation.json"
TODAY="$(date +%Y-%m-%d)"

if [ -f "$FOUNDATION_FILE" ]; then
  echo "    skip:    .claude/foundation.json  (exists — use /sync to update)"
else
  cat > "$FOUNDATION_FILE" <<EOF
{
  "kit": {
    "repo": "$KIT_REPO_URL",
    "branch": "$KIT_BRANCH"
  },
  "pinned_sha": "$KIT_SHA",
  "last_synced": "$TODAY",
  "overrides": []
}
EOF
  echo "    create:  .claude/foundation.json  (pinned to ${KIT_SHA:0:12})"
fi

# --- 4. Scaffold directories ------------------------------------------

echo
echo "→ Scaffolding directories"

scaffold_dir() {
  local dir="$1"
  local label="$2"
  mkdir -p "$TARGET/$dir"
  if [ ! -f "$TARGET/$dir/.gitkeep" ] && [ -z "$(ls -A "$TARGET/$dir" 2>/dev/null)" ]; then
    touch "$TARGET/$dir/.gitkeep"
    echo "    create:  $label/.gitkeep"
  else
    echo "    skip:    $label  (not empty)"
  fi
}

scaffold_dir "tasks/backlog"      "tasks/backlog"
scaffold_dir "tasks/active"       "tasks/active"
scaffold_dir "tasks/done"         "tasks/done"
scaffold_dir "docs/decisions"     "docs/decisions"
scaffold_dir "docs/postmortems"   "docs/postmortems"

# Skill output destinations (v0.4.0+ skills write durable docs here).
scaffold_dir "docs/notes"         "docs/notes"
scaffold_dir "docs/audits"        "docs/audits"
scaffold_dir "docs/handoff"       "docs/handoff"
scaffold_dir "docs/regrets"       "docs/regrets"
scaffold_dir "docs/retros"        "docs/retros"
scaffold_dir "docs/blast-radius"  "docs/blast-radius"
scaffold_dir "docs/scope"         "docs/scope"
scaffold_dir "docs/exports"       "docs/exports"
scaffold_dir "docs/proto"         "docs/proto"
scaffold_dir "docs/mvp"           "docs/mvp"
scaffold_dir "docs/refinement"    "docs/refinement"
scaffold_dir ".claude/tradeoffs"  ".claude/tradeoffs"
scaffold_dir ".claude/inbox"      ".claude/inbox"

# --- 5. Next steps ----------------------------------------------------

cat <<EOF

✅ claude-kit installed.

Next steps:
  1. Open CLAUDE.md and fill in the {{PLACEHOLDERS}} for this project
     (tech stack, build/test/run/deploy commands, schema ownership,
     and **declare the project's platform** in the "## Platform"
     section so the right .claude/<platform>-*.md files apply).
  2. Open tasks/PHASES.md and tasks/ROADMAP.md to draft your first
     phase + tasks. (Or run /plan to think through it.)
  3. Run /skills inside Claude Code to confirm the skill set.
  4. Run /status anytime for a project snapshot.

About the platform-prefixed files (ios-*, web-*, python-*, etc.):
  - All of them get installed regardless of platform — the prefix
    is a discovery hint, not a gate.
  - Agents read the prefix files relevant to the work at hand. The
    "## Platform" declaration in CLAUDE.md tells them which.
  - Cross-boundary work (e.g. iOS app to Python API) reads multiple
    prefix files naturally.

When the kit gets new versions later:
  - Run /sync inside Claude Code to pull updates.
  - Project files (CLAUDE.md, PHASES.md, AUDIT.md, etc.) are never
    touched by /sync. Skills and task-rules.md are.

Source: $KIT_REPO_URL
EOF
