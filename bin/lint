#!/usr/bin/env bash
#
# bin/lint — kit linter
#
# Catches platform-specific content that's drifted into universal kit
# files. The kit's naming convention says iOS-specific stuff goes in
# `ios-task-rules.md`, web-specific in `web-task-rules.md`, etc. —
# universal files (no platform prefix) should stay platform-neutral.
# Nothing else enforces this; this script does.
#
# Scope:
#   - kit/*.md whose basename does NOT start with a platform prefix
#   - kit/skills/<name>/SKILL.md where <name> does NOT start with a
#     platform prefix
#   - bootstrap/*.template (universal templates) with the same
#     exclusion rule
#
# Output: §6 Severity audit — severity bars + finding rows.
# Exit code: non-zero if any HIGH findings; zero otherwise.
#
# Architecture: bash for orchestration; one awk pass per file does
# the matching, context-window analysis, and severity classification.
# This keeps the runtime bounded — no per-hit subprocess forks.

set -euo pipefail

# ----------------------------------------------------------------------
# Locate repo root.
# ----------------------------------------------------------------------

script_path="${BASH_SOURCE[0]}"
while [ -L "$script_path" ]; do
  link_target="$(readlink "$script_path")"
  case "$link_target" in
    /*) script_path="$link_target" ;;
    *)  script_path="$(cd "$(dirname "$script_path")" && pwd)/$link_target" ;;
  esac
done
REPO_ROOT="$(cd "$(dirname "$script_path")/.." && pwd)"

# ----------------------------------------------------------------------
# Color setup (semantic, glyph-backed per output-styles.md).
# ----------------------------------------------------------------------

if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_ORANGE=$'\033[38;5;208m'
  C_YELLOW=$'\033[33m'
  C_BLUE=$'\033[34m'
  C_GRAY=$'\033[90m'
  C_BOLD=$'\033[1m'
  C_RESET=$'\033[0m'
else
  C_ORANGE=""
  C_YELLOW=""
  C_BLUE=""
  C_GRAY=""
  C_BOLD=""
  C_RESET=""
fi

# ----------------------------------------------------------------------
# Source-file enumeration.
# ----------------------------------------------------------------------

PLATFORM_PREFIXES=(ios android web python go ruby rust kotlin swift)

is_universal_basename() {
  local base="$1"
  for p in "${PLATFORM_PREFIXES[@]}"; do
    case "$base" in
      "${p}-"*) return 1 ;;
    esac
  done
  return 0
}

enumerate_sources() {
  if [ -d "$REPO_ROOT/kit" ]; then
    for f in "$REPO_ROOT/kit"/*.md; do
      [ -e "$f" ] || continue
      base="$(basename "$f")"
      if is_universal_basename "$base"; then
        echo "$f"
      fi
    done
  fi

  if [ -d "$REPO_ROOT/kit/skills" ]; then
    for d in "$REPO_ROOT/kit/skills"/*/; do
      [ -e "$d" ] || continue
      d="${d%/}"
      name="$(basename "$d")"
      if is_universal_basename "$name"; then
        skill="$d/SKILL.md"
        [ -f "$skill" ] && echo "$skill"
      fi
    done
  fi

  if [ -d "$REPO_ROOT/bootstrap" ]; then
    for f in "$REPO_ROOT/bootstrap"/*.template; do
      [ -e "$f" ] || continue
      base="$(basename "$f")"
      if is_universal_basename "$base"; then
        echo "$f"
      fi
    done
  fi
}

# ----------------------------------------------------------------------
# Per-file scan via awk. One pass per file:
#   - reads all lines into memory
#   - for each line, counts which platforms match
#   - for each match, classifies severity using:
#       (a) the line itself (table row, blockquote, "etc.", many
#           backticks, multiple platforms)
#       (b) the ±2 line context window
#   - emits TSV: severity \t platform \t relpath \t lineno \t
#                token \t cleaned_text
#
# Inherently cross-cutting files (CLAUDE.md template, batch-handoff,
# release-rules, output-rules, output-styles, task-template) get a
# severity floor drop: HIGH→MEDIUM. Single-platform tokens still
# raise to MEDIUM in those because they're worth surfacing during
# review even if the usual answer is "expected here."
# ----------------------------------------------------------------------

# The seven platform regexes.
#
# IMPORTANT: BSD awk on macOS does NOT support \b word boundaries.
# Word-boundary semantics are emulated by padding the search string
# with whitespace inside the awk pass and matching against a [^A-Za-z0-9_]
# delimiter on either side of "soft" tokens.
#
# Tokens fall into two camps:
#   - "Hard" tokens that include punctuation or compound chars
#     (e.g. ".xcodeproj", "package.json", "go.mod") — these match
#     unambiguously without boundary tricks.
#   - "Soft" tokens that are generic English words (e.g. "Combine",
#     "Realm", "React", "vite", "cargo", "gradle") — wrapped in
#     [^A-Za-z0-9_] padding to avoid sub-word matches.
RE_IOS='xcodebuild|xcrun|altool|fastlane|AVKit|AVPlayer|AVFoundation|SwiftUI|UIKit|SwiftData|[^A-Za-z0-9_]Combine[^A-Za-z0-9_]|\.xcodeproj|\.xcworkspace|Package\.swift|Podfile|[^A-Za-z0-9_]Realm[^A-Za-z0-9_]|Kingfisher|Cocoapods|TestFlight|NSObject|developer\.apple\.com'
RE_ANDROID='[^A-Za-z0-9_]gradle[^A-Za-z0-9_]|build\.gradle|Jetpack Compose|[^A-Za-z0-9_]Kotlin[^A-Za-z0-9_]|Room database|[^A-Za-z0-9_]Hilt[^A-Za-z0-9_]|Coroutines|CameraX|[^A-Za-z0-9_]Coil[^A-Za-z0-9_]|AndroidX|AndroidManifest|developer\.android\.com'
RE_WEB='package\.json|npm install|npm run|yarn add|[^A-Za-z0-9_]pnpm[^A-Za-z0-9_]|[^A-Za-z0-9_]React[^A-Za-z0-9_]|[^A-Za-z0-9_]Vue[^A-Za-z0-9_]|Next\.js|[^A-Za-z0-9_]Svelte[^A-Za-z0-9_]|[^A-Za-z0-9_]Nuxt[^A-Za-z0-9_]|[^A-Za-z0-9_]vite[^A-Za-z0-9_]|[^A-Za-z0-9_]webpack[^A-Za-z0-9_]|tailwindcss|react\.dev|vuejs\.org'
RE_PYTHON='pyproject\.toml|requirements\.txt|[^A-Za-z0-9_]pip install|[^A-Za-z0-9_]poetry[^A-Za-z0-9_]|[^A-Za-z0-9_]Flask[^A-Za-z0-9_]|[^A-Za-z0-9_]FastAPI[^A-Za-z0-9_]|[^A-Za-z0-9_]Django[^A-Za-z0-9_]|[^A-Za-z0-9_]pandas[^A-Za-z0-9_]|[^A-Za-z0-9_]numpy[^A-Za-z0-9_]|[^A-Za-z0-9_]pytest[^A-Za-z0-9_]'
RE_GO='go\.mod|go\.sum|[^A-Za-z0-9_]golang[^A-Za-z0-9_]|[^A-Za-z0-9_]Gin[^A-Za-z0-9_]|Echo framework|[^A-Za-z0-9_]Fiber[^A-Za-z0-9_]'
RE_RUBY='Gemfile|[^A-Za-z0-9_]bundler[^A-Za-z0-9_]|[^A-Za-z0-9_]Rails[^A-Za-z0-9_]|[^A-Za-z0-9_]RSpec[^A-Za-z0-9_]|[^A-Za-z0-9_]Sinatra[^A-Za-z0-9_]'
RE_RUST='Cargo\.toml|Cargo\.lock|[^A-Za-z0-9_]cargo[^A-Za-z0-9_]|[^A-Za-z0-9_]rustup[^A-Za-z0-9_]'

# Inherently cross-cutting basename list — colon-separated for awk.
CROSS_CUTTING_BASENAMES='CLAUDE.md.template:AUDIT.md.template:PHASES.md.template:ROADMAP.md.template:task-template.md:batch-handoff.md:release-rules.md:output-rules.md:output-styles.md'

scan_file_via_awk() {
  local file="$1"
  local rel="${file#$REPO_ROOT/}"
  local base
  base="$(basename "$file")"

  awk -v REL="$rel" -v BASE="$base" \
      -v RE_IOS="$RE_IOS" -v RE_ANDROID="$RE_ANDROID" -v RE_WEB="$RE_WEB" \
      -v RE_PYTHON="$RE_PYTHON" -v RE_GO="$RE_GO" -v RE_RUBY="$RE_RUBY" \
      -v RE_RUST="$RE_RUST" \
      -v CROSS_CUTTING="$CROSS_CUTTING_BASENAMES" '
    BEGIN {
      # Build cross-cutting set.
      n = split(CROSS_CUTTING, parts, ":")
      for (i = 1; i <= n; i++) {
        cross_cutting[parts[i]] = 1
      }
      is_cross_cutting = (BASE in cross_cutting) ? 1 : 0

      labels[1] = "iOS"
      labels[2] = "Android"
      labels[3] = "Web"
      labels[4] = "Python"
      labels[5] = "Go"
      labels[6] = "Ruby"
      labels[7] = "Rust"
      regexes[1] = RE_IOS
      regexes[2] = RE_ANDROID
      regexes[3] = RE_WEB
      regexes[4] = RE_PYTHON
      regexes[5] = RE_GO
      regexes[6] = RE_RUBY
      regexes[7] = RE_RUST
      n_platforms = 7
    }

    # Slurp the whole file into an array so we can do ±5 context.
    { lines[NR] = $0 }

    END {
      total = NR
      for (n = 1; n <= total; n++) {
        line = lines[n]
        # Pad with spaces so soft tokens with [^A-Za-z0-9_] anchors
        # work at line boundaries.
        padded = " " line " "

        # Count platform matches on this line.
        line_platforms = 0
        for (k = 1; k <= n_platforms; k++) {
          if (match(padded, regexes[k])) {
            line_platforms_arr[k] = 1
            line_platforms++
          } else {
            line_platforms_arr[k] = 0
          }
        }

        # Skip lines with no platform hits.
        if (line_platforms == 0) continue

        # Count platforms in the ±5 line context window.
        # ±5 catches typical "per-platform bullet lists" where each
        # row is one platform but the surrounding rows enumerate the
        # rest. Reference docs use this pattern heavily.
        ctx_lo = (n - 5 < 1 ? 1 : n - 5)
        ctx_hi = (n + 5 > total ? total : n + 5)
        ctx_text = " "
        for (m = ctx_lo; m <= ctx_hi; m++) {
          ctx_text = ctx_text " " lines[m] " "
        }
        ctx_platforms_count = 0
        for (k = 1; k <= n_platforms; k++) {
          if (match(ctx_text, regexes[k])) ctx_platforms_count++
        }

        # Cross-platform-cue check: tokens that signal "this
        # paragraph is talking about multiple ecosystems generically"
        # without naming a specific platform. node_modules/, vendor/,
        # virtualenv, manifest, toolchain, ecosystem. Combined with
        # 1+ platform-token in the window, this is reference context.
        cue_match = match(ctx_text, /node_modules|[^A-Za-z0-9_]vendor[^A-Za-z0-9_]|virtualenv|[^A-Za-z0-9_]venv[^A-Za-z0-9_]|toolchain|ecosystem|manifest|lockfile|[^A-Za-z0-9_]rbenv|[^A-Za-z0-9_]pyenv|[^A-Za-z0-9_]nvm[^A-Za-z0-9_]|asdf/)

        # Section-back scan: walk backwards from the hit until we
        # find a markdown heading (^#) or hit ±15 lines, looking
        # for explicit example markers ("Examples:", "Detect ...",
        # "per ecosystem", "Detected: ..."). If found, this is a
        # reference context, not drift.
        section_marker_match = 0
        sb_lo = (n - 15 < 1 ? 1 : n - 15)
        for (m = n; m >= sb_lo; m--) {
          row = lines[m]
          # Stop scan at section heading.
          if (row ~ /^#+ /) break
          if (row ~ /Examples?:|Examples? to delete|Detect the|Detected:|per ecosystem|per platform|For each (platform|toolchain|ecosystem)|For (iOS|Web|Python|Android|Go|Ruby|Rust)/) {
            section_marker_match = 1
            break
          }
        }

        # Compute line-shape signals.
        # Trim leading whitespace for shape checks.
        trimmed = line
        sub(/^[[:space:]]+/, "", trimmed)

        is_table_row = (substr(trimmed, 1, 1) == "|") ? 1 : 0
        is_blockquote = (substr(trimmed, 1, 1) == ">") ? 1 : 0

        # Backtick density.
        tick_count = gsub(/`/, "`", line)

        # Pipe density.
        pipe_count = gsub(/\|/, "|", line)

        # "Example" / "etc." markers in the line itself.
        line_marker_match = match(line, /etc\.|e\.g\.|E\.g\.|i\.e\.|or similar|or documented|Example[s]?[[:space:]]|Example[s]?:|Examples to delete|Example to delete/)

        # Quoted-example pattern: line (or surrounding ±5 context)
        # contains a quoted phrase AND the platform token is inside
        # it. This is style-rule example language — kits use it to
        # demonstrate "right vs wrong" phrasing.
        # Heuristic: 2+ double-quote characters in window.
        ctx_quote_count = gsub(/"/, "\"", ctx_text)
        is_quoted_example = (ctx_quote_count >= 2) ? 1 : 0
        # (gsub above already counted; the match() resets so we just
        #  need the boolean. NB: awk match() returns position, 0 if
        #  no match.)

        # Context-marker check (template / placeholder / examples /
        # quoted phrases / etc.).
        ctx_marker_match = match(ctx_text, /Examples to delete|Example to delete|\{\{|<TODO|<placeholder|TODO:|placeholder|^Examples?:|Examples?[[:space:]]|etc\.|e\.g\.|i\.e\.|or similar|or documented/)

        # For each platform that matched the line, emit one finding.
        for (k = 1; k <= n_platforms; k++) {
          if (!line_platforms_arr[k]) continue

          # Pull the matched token for display. Match against the
          # padded line so soft-token regexes work; then strip the
          # boundary chars from the displayed token.
          if (match(padded, regexes[k])) {
            token = substr(padded, RSTART, RLENGTH)
            # Strip leading/trailing non-word chars introduced by
            # the [^A-Za-z0-9_] padding pattern.
            sub(/^[^A-Za-z0-9_.\\-]+/, "", token)
            sub(/[^A-Za-z0-9_.\\-]+$/, "", token)
          } else {
            token = "(match)"
          }

          # Severity classification.
          severity = "HIGH"

          if (is_blockquote || is_table_row) {
            severity = "LOW"
          } else if (line_marker_match > 0) {
            severity = "LOW"
          } else if (tick_count >= 6) {
            severity = "LOW"
          } else if (pipe_count >= 3) {
            severity = "LOW"
          } else if (line_platforms >= 2) {
            severity = "LOW"
          } else if (ctx_platforms_count >= 2) {
            severity = "LOW"
          } else if (section_marker_match) {
            severity = "LOW"
          } else if (cue_match > 0) {
            # Cross-ecosystem cue word in window (node_modules,
            # vendor, virtualenv, toolchain, etc.) — paragraph is
            # talking about ecosystems generically.
            severity = "LOW"
          } else if (is_quoted_example) {
            severity = "LOW"
          } else if (ctx_marker_match > 0) {
            # Context has Example/Placeholder markers but the line
            # itself reads platform-only. Worth a look but not a
            # blocker.
            severity = "MEDIUM"
          }

          # Cross-cutting file floor: HIGH never sticks in these
          # files; demote to MEDIUM.
          if (is_cross_cutting && severity == "HIGH") {
            severity = "MEDIUM"
          }

          # Clean text for display: strip tabs, cut to 100 chars.
          clean = line
          gsub(/\t/, " ", clean)
          if (length(clean) > 100) clean = substr(clean, 1, 100)

          printf "%s\t%s\t%s\t%d\t%s\t%s\n", \
            severity, labels[k], REL, n, token, clean
        }
      }
    }
  ' "$file"
}

# ----------------------------------------------------------------------
# Render — §6 Severity audit.
# ----------------------------------------------------------------------

target_file_for_label() {
  case "$1" in
    iOS)     printf '%s' 'ios-' ;;
    Android) printf '%s' 'android-' ;;
    Web)     printf '%s' 'web-' ;;
    Python)  printf '%s' 'python-' ;;
    Go)      printf '%s' 'go-' ;;
    Ruby)    printf '%s' 'ruby-' ;;
    Rust)    printf '%s' 'rust-' ;;
    *)       printf '%s' '<platform>-' ;;
  esac
}

render_bar() {
  local n="$1"
  local maxlen="${2:-36}"
  local bar=""
  if [ "$n" -gt 0 ]; then
    local len=$(( n * maxlen / (n + 4) ))
    [ "$len" -lt 4 ] && len=4
    [ "$len" -gt "$maxlen" ] && len="$maxlen"
    local i=0
    while [ "$i" -lt "$len" ]; do
      bar="${bar}━"
      i=$((i + 1))
    done
  fi
  printf '%s' "$bar"
}

sev_color() {
  case "$1" in
    HIGH)   printf '%s' "$C_ORANGE" ;;
    MEDIUM) printf '%s' "$C_YELLOW" ;;
    LOW)    printf '%s' "$C_BLUE"  ;;
    *)      printf '%s' "$C_GRAY"  ;;
  esac
}

main() {
  local sources file_count=0
  sources="$(enumerate_sources)"
  if [ -z "$sources" ]; then
    echo "lint: no universal kit files found under $REPO_ROOT"
    exit 0
  fi

  local findings_tmp
  findings_tmp="$(mktemp -t lint-kit.XXXXXX)"
  # shellcheck disable=SC2064
  trap "rm -f '$findings_tmp'" EXIT

  while IFS= read -r f; do
    [ -z "$f" ] && continue
    file_count=$((file_count + 1))
    scan_file_via_awk "$f" >> "$findings_tmp"
  done <<< "$sources"

  local n_high n_medium n_low n_total
  n_high=$(awk -F'\t' '$1 == "HIGH"   {c++} END {print c+0}' "$findings_tmp")
  n_medium=$(awk -F'\t' '$1 == "MEDIUM" {c++} END {print c+0}' "$findings_tmp")
  n_low=$(awk -F'\t' '$1 == "LOW"    {c++} END {print c+0}' "$findings_tmp")
  n_total=$(( n_high + n_medium + n_low ))

  echo
  printf '  %sKIT LINT%s   ·   %s findings across %s universal files\n' \
    "$C_BOLD" "$C_RESET" "$n_total" "$file_count"
  echo
  echo

  if [ "$n_total" -eq 0 ]; then
    printf '  %s✓  Clean. Universal kit files contain no detectable platform-specific drift.%s\n' \
      "$C_GRAY" "$C_RESET"
    echo
    exit 0
  fi

  if [ "$n_high" -gt 0 ]; then
    printf '  %s●  HIGH      %s%-40s%s%4d%s\n' \
      "$C_ORANGE" "$C_ORANGE" "$(render_bar "$n_high")" "$C_RESET" "$n_high" "$C_RESET"
  fi
  if [ "$n_medium" -gt 0 ]; then
    printf '  %s●  MEDIUM    %s%-40s%s%4d%s\n' \
      "$C_YELLOW" "$C_YELLOW" "$(render_bar "$n_medium")" "$C_RESET" "$n_medium" "$C_RESET"
  fi
  if [ "$n_low" -gt 0 ]; then
    printf '  %s●  LOW       %s%-40s%s%4d%s\n' \
      "$C_BLUE" "$C_BLUE" "$(render_bar "$n_low")" "$C_RESET" "$n_low" "$C_RESET"
  fi

  echo
  echo

  while IFS=$'\t' read -r sev platform rel lineno matched text; do
    [ -z "$sev" ] && continue
    color="$(sev_color "$sev")"
    target="$(target_file_for_label "$platform")"
    display_text="$(printf '%s' "$text" | sed -E 's/^[[:space:]]+//' | cut -c 1-100)"

    printf '  %s▌ %-7s%s  ·  %s:%s\n' \
      "$color" "$sev" "$C_RESET" "$rel" "$lineno"
    printf '    %s%s%s found · %s\n' \
      "$C_GRAY" "$matched" "$C_RESET" "$display_text"
    printf '    └─ move to a %s%s*%s file (e.g. `%stask-rules.md`, `kit/skills/%s<name>/`)\n' \
      "$C_GRAY" "$target" "$C_RESET" "$target" "$target"
    echo
  done < <(awk -F'\t' '$1 == "HIGH" || $1 == "MEDIUM"' "$findings_tmp" \
            | sort -t$'\t' -k1,1 -k3,3 -k4,4n)

  if [ "$n_low" -gt 0 ]; then
    local plural=""
    [ "$n_low" -ne 1 ] && plural="s"
    printf '  %s⋮  %d LOW finding%s suppressed (multi-platform reference contexts) · re-run with VERBOSE=1 to show%s\n' \
      "$C_GRAY" "$n_low" "$plural" "$C_RESET"
    echo
  fi

  if [ -n "${VERBOSE:-}" ] && [ "$n_low" -gt 0 ]; then
    while IFS=$'\t' read -r sev platform rel lineno matched text; do
      [ -z "$sev" ] && continue
      color="$(sev_color "$sev")"
      display_text="$(printf '%s' "$text" | sed -E 's/^[[:space:]]+//' | cut -c 1-100)"
      printf '  %s▌ %-7s%s  ·  %s:%s\n' "$color" "$sev" "$C_RESET" "$rel" "$lineno"
      printf '    %s%s%s · %s\n' "$C_GRAY" "$matched" "$C_RESET" "$display_text"
      echo
    done < <(awk -F'\t' '$1 == "LOW"' "$findings_tmp" \
              | sort -t$'\t' -k3,3 -k4,4n)
  fi

  if [ "$n_high" -gt 0 ]; then
    exit 1
  fi
  exit 0
}

main "$@"
